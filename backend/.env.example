# Copiar a .env y editar. NUNCA subir el .env real al repositorio.

DATABASE_URL=postgresql://usuario:password@localhost:5432/bbva_interno
SECRET_KEY=cambiar-por-una-llave-aleatoria-larga
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Receptor de las facturas (empresa pagadora)
RFC_RECEPTOR=XXX000000XX0
NOMBRE_RECEPTOR=NOMBRE DE LA EMPRESA

# Superadmin inicial — generar hash con:
# uv run python -c "from app.core.security import hash_password; print(hash_password('TU_PASSWORD'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$cambiar-por-hash-bcrypt

# IMAP — buzón del que se leen facturas (Google Workspace: App Password)
# Mientras IMAP_PASSWORD tenga el placeholder, el watcher queda inactivo.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=buzon@tudominio.com
IMAP_PASSWORD=pon-aqui-tu-app-password
IMAP_POLL_MINUTES=5
